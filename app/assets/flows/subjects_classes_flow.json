{
  "data_api_version": "3.0",
  "version": "7.3",
  "routing_model": {
    "select_subject": ["select_classes"],
    "select_classes": []
  },
  "screens": [
    {
      "id": "select_subject",
      "title": "Select Subjects",
      "terminal": false,
      "refresh_on_back": true,
      "data": {
        "subject_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "1", "title": "Mathematics" },
            { "id": "2", "title": "Biology" }
          ]
        },
        "selected_subject_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["1"]
        },
        "has_subject_options": {
          "type": "boolean",
          "__example__": true
        },
        "select_subject_text": {
          "type": "string",
          "__example__": "Choose up to 3 subjects, then continue to classes."
        },
        "configured_subjects_text": {
          "type": "string",
          "__example__": "Configured subjects: 2"
        },
        "no_subjects_text": {
          "type": "string",
          "__example__": "Sorry, there are no available subjects."
        },
        "subject_dropdown_label": {
          "type": "string",
          "__example__": "Subjects"
        },
        "max_selected_subjects": {
          "type": "number",
          "__example__": 3
        },
        "complete_button_label": {
          "type": "string",
          "__example__": "Continue"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextBody",
            "text": "${data.select_subject_text}"
          },
          {
            "type": "TextCaption",
            "text": "${data.configured_subjects_text}"
          },
          {
            "type": "If",
            "condition": "${data.has_subject_options}",
            "then": [
              {
                "type": "ChipsSelector",
                "name": "selected_subject_ids",
                "label": "${data.subject_dropdown_label}",
                "required": true,
                "data-source": "${data.subject_options}",
                "init-value": "${data.selected_subject_ids}",
                "max-selected-items": "${data.max_selected_subjects}"
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "${data.no_subjects_text}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "${data.complete_button_label}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "load_subject_classes",
                "selected_subject_ids": "${form.selected_subject_ids}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "select_classes",
      "title": "Select Classes",
      "terminal": true,
      "refresh_on_back": true,
      "data": {
        "selected_subject_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["1", "2"]
        },
        "selected_subjects_label": {
          "type": "string",
          "__example__": "Mathematics, Biology"
        },
        "has_classes": {
          "type": "boolean",
          "__example__": true
        },
        "classes_for_subject": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "201", "title": "Biology - Form 1" },
            { "id": "101", "title": "Mathematics - Form 1" },
            { "id": "102", "title": "Mathematics - Form 2" }
          ]
        },
        "selected_class_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["101"]
        },
        "classes_label": {
          "type": "string",
          "__example__": "Select classes"
        },
        "max_selected_classes": {
          "type": "number",
          "__example__": 10
        },
        "save_button_label": {
          "type": "string",
          "__example__": "Complete"
        },
        "no_classes_text": {
          "type": "string",
          "__example__": "No active classes are available for selected subjects."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "${data.selected_subjects_label}"
          },
          {
            "type": "If",
            "condition": "${data.has_classes}",
            "then": [
              {
                "type": "ChipsSelector",
                "name": "selected_class_ids",
                "label": "${data.classes_label}",
                "required": true,
                "data-source": "${data.classes_for_subject}",
                "init-value": "${data.selected_class_ids}",
                "min-selected-items": 1,
                "max-selected-items": "${data.max_selected_classes}"
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "${data.no_classes_text}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "${data.save_button_label}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "complete_subject_configuration",
                "selected_subject_ids": "${data.selected_subject_ids}",
                "selected_class_ids": "${form.selected_class_ids}"
              }
            }
          }
        ]
      }
    }
  ]
}
