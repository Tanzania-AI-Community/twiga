{
  "data_api_version": "3.0",
  "version": "7.3",
  "routing_model": {
    "select_subject": ["select_classes"],
    "select_classes": []
  },
  "screens": [
    {
      "id": "select_subject",
      "title": "Select Subject",
      "terminal": false,
      "refresh_on_back": true,
      "data": {
        "subject_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "1", "title": "Mathematics" },
            { "id": "2", "title": "Biology" }
          ]
        },
        "has_subject_options": {
          "type": "boolean",
          "__example__": true
        },
        "select_subject_text": {
          "type": "string",
          "__example__": "Select a subject, save its classes, then repeat for other subjects."
        },
        "configured_subjects_text": {
          "type": "string",
          "__example__": "Configured subjects: 2"
        },
        "no_subjects_text": {
          "type": "string",
          "__example__": "Sorry, there are no available subjects."
        },
        "subject_dropdown_label": {
          "type": "string",
          "__example__": "Subject"
        },
        "complete_button_label": {
          "type": "string",
          "__example__": "Complete"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextBody",
            "text": "${data.select_subject_text}"
          },
          {
            "type": "TextCaption",
            "text": "${data.configured_subjects_text}"
          },
          {
            "type": "If",
            "condition": "${data.has_subject_options}",
            "then": [
              {
                "type": "Dropdown",
                "name": "selected_subject_id",
                "label": "${data.subject_dropdown_label}",
                "required": true,
                "data-source": "${data.subject_options}",
                "on-select-action": {
                  "name": "data_exchange",
                  "payload": {
                    "component_action": "load_subject_classes",
                    "selected_subject_id": "${form.selected_subject_id}"
                  }
                }
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "${data.no_subjects_text}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "${data.complete_button_label}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "complete_subject_configuration"
              }
            }
          }
        ]
      }
    },
    {
      "id": "select_classes",
      "title": "Select Classes",
      "terminal": true,
      "refresh_on_back": true,
      "data": {
        "selected_subject_id": {
          "type": "string",
          "__example__": "1"
        },
        "selected_subject_label": {
          "type": "string",
          "__example__": "Mathematics"
        },
        "has_classes": {
          "type": "boolean",
          "__example__": true
        },
        "classes_for_subject": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "101", "title": "Form 1" },
            { "id": "102", "title": "Form 2" }
          ]
        },
        "selected_classes_for_subject": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["101"]
        },
        "classes_label": {
          "type": "string",
          "__example__": "Select classes"
        },
        "save_button_label": {
          "type": "string",
          "__example__": "Save Subject"
        },
        "no_classes_text": {
          "type": "string",
          "__example__": "No active classes are available for this subject."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "${data.selected_subject_label}"
          },
          {
            "type": "If",
            "condition": "${data.has_classes}",
            "then": [
              {
                "type": "CheckboxGroup",
                "name": "selected_classes",
                "label": "${data.classes_label}",
                "required": false,
                "data-source": "${data.classes_for_subject}",
                "init-value": "${data.selected_classes_for_subject}"
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "${data.no_classes_text}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "${data.save_button_label}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "save_subject_classes",
                "selected_subject_id": "${data.selected_subject_id}",
                "selected_class_ids": "${form.selected_classes}"
              }
            }
          }
        ]
      }
    }
  ]
}
