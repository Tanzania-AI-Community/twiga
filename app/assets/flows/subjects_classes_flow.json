{
  "data_api_version": "3.0",
  "version": "7.3",
  "routing_model": {
    "select_subject": ["select_classes"],
    "select_classes": []
  },
  "screens": [
    {
      "id": "select_subject",
      "title": "Select Subjects",
      "terminal": false,
      "refresh_on_back": true,
      "data": {
        "subject_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "1", "title": "🌎 Geography" },
            { "id": "2", "title": "📙 History" },
            { "id": "3", "title": "🧬 Biology" },
            { "id": "4", "title": "📘 English" },
            { "id": "5", "title": "🏛️ Civics" },
            { "id": "6", "title": "➗ Mathematics" },
            { "id": "7", "title": "👤 Human Geography" },
            { "id": "8", "title": "🪨 Physical Geography" },
            { "id": "9", "title": "🌽 Agriculture" },
            { "id": "10", "title": "🚜 Agromechanics" },
            { "id": "11", "title": "🐮 Animal Health And Production" },
            { "id": "12", "title": "👨‍🎨 Arts And Design" },
            { "id": "13", "title": "🔧 Auto Body Repair" },
            { "id": "14", "title": "✝️ Bible Knowledge" },
            { "id": "15", "title": "📚 Book Keeping" },
            { "id": "16", "title": "⚛️ Chemistry" },
            { "id": "17", "title": "💻 Computer Science" },
            { "id": "18", "title": "📐 Engineering Science" },
            { "id": "19", "title": "🚀 Physics" },
            { "id": "20", "title": "🎭 Acting" },
            { "id": "21", "title": "💼 Business Studies" },
            { "id": "22", "title": "➕ Additional Mathematics" },
            { "id": "23", "title": "🚗 Auto Electric" },
            { "id": "24", "title": "🪚 Carpentry" },
            { "id": "25", "title": "📏 Civil Draughting" },
            { "id": "26", "title": "🌱 Horticultural Production" },
            { "id": "27", "title": "👞 Leather Goods And Footwear" },
            { "id": "28", "title": "📖 Literature In English" },
            { "id": "29", "title": "🖥️ Information And Computer Studies" },
            { "id": "30", "title": "💹 Commerce" }
          ]
        },
        "selected_subject_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["1"]
        },
        "has_subject_options": {
          "type": "boolean",
          "__example__": true
        },
        "no_subjects_text": {
          "type": "string",
          "__example__": "Sorry, currently there are no available subjects."
        },
        "subject_dropdown_label": {
          "type": "string",
          "__example__": "Subjects"
        },
        "max_selected_subjects": {
          "type": "number",
          "__example__": 3
        },
        "complete_button_label": {
          "type": "string",
          "__example__": "Continue"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "If",
            "condition": "${data.has_subject_options}",
            "then": [
              {
                "type": "ChipsSelector",
                "name": "selected_subject_ids",
                "label": "${data.subject_dropdown_label}",
                "required": true,
                "data-source": "${data.subject_options}",
                "init-value": "${data.selected_subject_ids}",
                "max-selected-items": "${data.max_selected_subjects}"
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "${data.no_subjects_text}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "${data.complete_button_label}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "load_subject_classes",
                "selected_subject_ids": "${form.selected_subject_ids}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "select_classes",
      "title": "Select Classes",
      "terminal": true,
      "refresh_on_back": true,
      "data": {
        "selected_subject_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["3", "4", "6"]
        },
        "selected_subjects_label": {
          "type": "string",
          "__example__": "Biology, English, Mathematics"
        },
        "has_classes": {
          "type": "boolean",
          "__example__": true
        },
        "classes_for_subject": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "301", "title": "Biology - Form 1" },
            { "id": "302", "title": "Biology - Form 2" },
            { "id": "303", "title": "Biology - Form 3" },
            { "id": "304", "title": "Biology - Form 4" },
            { "id": "305", "title": "Biology - Form 5" },
            { "id": "306", "title": "Biology - Form 6" },
            { "id": "401", "title": "English - Form 1" },
            { "id": "402", "title": "English - Form 2" },
            { "id": "403", "title": "English - Form 3" },
            { "id": "404", "title": "English - Form 4" },
            { "id": "405", "title": "English - Form 5" },
            { "id": "406", "title": "English - Form 6" },
            { "id": "601", "title": "Mathematics - Form 1" },
            { "id": "602", "title": "Mathematics - Form 2" },
            { "id": "603", "title": "Mathematics - Form 3" },
            { "id": "604", "title": "Mathematics - Form 4" },
            { "id": "605", "title": "Mathematics - Form 5" },
            { "id": "606", "title": "Mathematics - Form 6" }
          ]
        },
        "selected_class_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["302", "601"]
        },
        "classes_label": {
          "type": "string",
          "__example__": "Select classes"
        },
        "max_selected_classes": {
          "type": "number",
          "__example__": 10
        },
        "save_button_label": {
          "type": "string",
          "__example__": "Complete"
        },
        "no_classes_text": {
          "type": "string",
          "__example__": "No active classes are available for selected subjects."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "${data.selected_subjects_label}"
          },
          {
            "type": "If",
            "condition": "${data.has_classes}",
            "then": [
              {
                "type": "ChipsSelector",
                "name": "selected_class_ids",
                "label": "${data.classes_label}",
                "required": true,
                "data-source": "${data.classes_for_subject}",
                "init-value": "${data.selected_class_ids}",
                "min-selected-items": 1,
                "max-selected-items": "${data.max_selected_classes}"
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "${data.no_classes_text}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "${data.save_button_label}",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "complete_subject_configuration",
                "selected_subject_ids": "${data.selected_subject_ids}",
                "selected_class_ids": "${form.selected_class_ids}"
              }
            }
          }
        ]
      }
    }
  ]
}
