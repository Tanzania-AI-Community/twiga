{
  "data_api_version": "3.0",
  "version": "7.3",
  "routing_model": {
    "select_subject": ["select_classes"],
    "select_classes": []
  },
  "screens": [
    {
      "id": "select_subject",
      "title": "Subject Selector",
      "terminal": false,
      "refresh_on_back": true,
      "data": {
        "subject_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "1", "title": "🌎 Geography" },
            { "id": "2", "title": "📙 History" },
            { "id": "3", "title": "🧬 Biology" },
            { "id": "4", "title": "📘 English" },
            { "id": "5", "title": "🏛️ Civics" },
            { "id": "6", "title": "➗ Mathematics" },
            { "id": "7", "title": "👤 Human Geography" },
            { "id": "8", "title": "🪨 Physical Geography" },
            { "id": "9", "title": "🌽 Agriculture" },
            { "id": "10", "title": "🚜 Agromechanics" },
            { "id": "11", "title": "🐮 Animal Health & Production" },
            { "id": "12", "title": "👨‍🎨 Arts & Design" },
            { "id": "13", "title": "🔧 Auto Body Repair" },
            { "id": "14", "title": "✝️ Bible Knowledge" },
            { "id": "15", "title": "📚 Bookkeeping" },
            { "id": "16", "title": "⚛️ Chemistry" },
            { "id": "17", "title": "💻 Computer Science" },
            { "id": "18", "title": "📐 Engineering Science" },
            { "id": "19", "title": "🚀 Physics" },
            { "id": "20", "title": "🎭 Acting" }
          ]
        },
        "selected_subject_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["1"]
        },
        "has_subject_options": {
          "type": "boolean",
          "__example__": true
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "If",
            "condition": "${data.has_subject_options}",
            "then": [
              {
                "type": "ChipsSelector",
                "name": "selected_subject_ids",
                "label": "Select your subjects",
                "required": true,
                "data-source": "${data.subject_options}",
                "init-value": "${data.selected_subject_ids}",
                "min-selected-items": 1,
                "max-selected-items": 3
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "Sorry, currently there are no available subjects. Please contact support (dev@ai.or.tz) for assistance."
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "load_subject_classes",
                "selected_subject_ids": "${form.selected_subject_ids}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "select_classes",
      "title": "Class Selector",
      "terminal": true,
      "refresh_on_back": true,
      "data": {
        "selected_subject_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["3", "4", "6"]
        },
        "has_classes": {
          "type": "boolean",
          "__example__": true
        },
        "classes_for_subject": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "301", "title": "Form 1 - Biology" },
            { "id": "302", "title": "Form 2 - Biology" },
            { "id": "303", "title": "Form 3 - Biology" },
            { "id": "304", "title": "Form 4 - Biology" },
            { "id": "305", "title": "Form 5 - Biology" },
            { "id": "306", "title": "Form 6 - Biology" },
            { "id": "401", "title": "Form 1 - English" },
            { "id": "402", "title": "Form 2 - English" },
            { "id": "403", "title": "Form 3 - English" },
            { "id": "404", "title": "Form 4 - English" },
            { "id": "405", "title": "Form 5 - English" },
            { "id": "406", "title": "Form 6 - English" },
            { "id": "601", "title": "Form 1 - Mathematics" },
            { "id": "602", "title": "Form 2 - Mathematics" },
            { "id": "603", "title": "Form 3 - Mathematics" },
            { "id": "604", "title": "Form 4 - Mathematics" },
            { "id": "605", "title": "Form 5 - Mathematics" },
            { "id": "606", "title": "Form 6 - Mathematics" }
          ]
        },
        "selected_class_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["302", "601"]
        },
        "no_classes_text": {
          "type": "string",
          "__example__": "No active classes are available for selected subjects. Please contact support (dev@ai.or.tz) for assistance."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "If",
            "condition": "${data.has_classes}",
            "then": [
              {
                "type": "ChipsSelector",
                "name": "selected_class_ids",
                "label": "Select your classes",
                "required": true,
                "data-source": "${data.classes_for_subject}",
                "init-value": "${data.selected_class_ids}",
                "min-selected-items": 1,
                "max-selected-items": 10
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "${data.no_classes_text}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Complete",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "complete_subject_configuration",
                "selected_subject_ids": "${data.selected_subject_ids}",
                "selected_class_ids": "${form.selected_class_ids}"
              }
            }
          }
        ]
      }
    }
  ]
}
