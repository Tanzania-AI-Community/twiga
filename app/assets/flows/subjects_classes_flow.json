{
  "data_api_version": "3.0",
  "version": "7.3",
  "routing_model": {
    "select_subject": ["select_classes"],
    "select_classes": []
  },
  "screens": [
    {
      "id": "select_subject",
      "title": "Subject Selector",
      "terminal": false,
      "refresh_on_back": true,
      "data": {
        "subject_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "1", "title": "Geography 🌎" },
            { "id": "2", "title": "History 📙" },
            { "id": "3", "title": "Biology 🧬" },
            { "id": "4", "title": "English 📘" },
            { "id": "5", "title": "Civics 🏛️" },
            { "id": "6", "title": "Mathematics ➗" },
            { "id": "7", "title": "Human Geography 👤" },
            { "id": "8", "title": "Physical Geography 🪨" },
            { "id": "9", "title": "Agriculture 🌽" },
            { "id": "10", "title": "Agromechanics 🚜" },
            { "id": "11", "title": "Animal Health & Production 🐮" },
            { "id": "12", "title": "Arts & Design 👨‍🎨" },
            { "id": "13", "title": "Auto Body Repair 🔧" },
            { "id": "14", "title": "Bible Knowledge ✝️" },
            { "id": "15", "title": "Bookkeeping 📚" },
            { "id": "16", "title": "Chemistry ⚛️" },
            { "id": "17", "title": "Computer Science 💻" },
            { "id": "18", "title": "Engineering Science 📐" },
            { "id": "19", "title": "Physics 🚀" },
            { "id": "20", "title": "Acting 🎭" }
          ]
        },
        "selected_subject_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["1"]
        },
        "has_subject_options": {
          "type": "boolean",
          "__example__": true
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "If",
            "condition": "${data.has_subject_options}",
            "then": [
              {
                "type": "ChipsSelector",
                "name": "selected_subject_ids",
                "label": "Select your subjects",
                "required": true,
                "data-source": "${data.subject_options}",
                "init-value": "${data.selected_subject_ids}",
                "min-selected-items": 1,
                "max-selected-items": 3
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "Sorry, currently there are no available subjects. Please contact support (dev@ai.or.tz) for assistance."
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "load_subject_classes",
                "selected_subject_ids": "${form.selected_subject_ids}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "select_classes",
      "title": "Class Selector",
      "terminal": true,
      "refresh_on_back": true,
      "data": {
        "selected_subject_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["3", "4", "6"]
        },
        "has_classes": {
          "type": "boolean",
          "__example__": true
        },
        "subject1_title": {
          "type": "string",
          "__example__": "Biology"
        },
        "subject1_has_classes": {
          "type": "boolean",
          "__example__": true
        },
        "subject1_class_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "301", "title": "Form 1" },
            { "id": "302", "title": "Form 2" },
            { "id": "303", "title": "Form 3" },
            { "id": "304", "title": "Form 4" },
            { "id": "305", "title": "Form 5" },
            { "id": "306", "title": "Form 6" }
          ]
        },
        "subject1_selected_class_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["302"]
        },
        "subject2_title": {
          "type": "string",
          "__example__": "English"
        },
        "subject2_has_classes": {
          "type": "boolean",
          "__example__": true
        },
        "subject2_class_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "401", "title": "Form 1" },
            { "id": "402", "title": "Form 2" },
            { "id": "403", "title": "Form 3" },
            { "id": "404", "title": "Form 4" },
            { "id": "405", "title": "Form 5" },
            { "id": "406", "title": "Form 6" }
          ]
        },
        "subject2_selected_class_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["401"]
        },
        "subject3_title": {
          "type": "string",
          "__example__": "Mathematics"
        },
        "subject3_has_classes": {
          "type": "boolean",
          "__example__": true
        },
        "subject3_class_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            { "id": "601", "title": "Form 1" },
            { "id": "602", "title": "Form 2" },
            { "id": "603", "title": "Form 3" },
            { "id": "604", "title": "Form 4" },
            { "id": "605", "title": "Form 5" },
            { "id": "606", "title": "Form 6" }
          ]
        },
        "subject3_selected_class_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["601"]
        },
        "no_classes_text": {
          "type": "string",
          "__example__": "No active classes are available for selected subjects. Please contact support (dev@ai.or.tz) for assistance."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "If",
            "condition": "${data.has_classes}",
            "then": [
              {
                "type": "TextSubheading",
                "text": "${data.subject1_title}",
                "visible": "${data.subject1_has_classes}"
              },
              {
                "type": "CheckboxGroup",
                "name": "subject1_selected_class_ids",
                "label": "Select classes",
                "required": false,
                "data-source": "${data.subject1_class_options}",
                "init-value": "${data.subject1_selected_class_ids}",
                "visible": "${data.subject1_has_classes}"
              },
              {
                "type": "TextSubheading",
                "text": "${data.subject2_title}",
                "visible": "${data.subject2_has_classes}"
              },
              {
                "type": "CheckboxGroup",
                "name": "subject2_selected_class_ids",
                "label": "Select classes",
                "required": false,
                "data-source": "${data.subject2_class_options}",
                "init-value": "${data.subject2_selected_class_ids}",
                "visible": "${data.subject2_has_classes}"
              },
              {
                "type": "TextSubheading",
                "text": "${data.subject3_title}",
                "visible": "${data.subject3_has_classes}"
              },
              {
                "type": "CheckboxGroup",
                "name": "subject3_selected_class_ids",
                "label": "Select classes",
                "required": false,
                "data-source": "${data.subject3_class_options}",
                "init-value": "${data.subject3_selected_class_ids}",
                "visible": "${data.subject3_has_classes}"
              }
            ],
            "else": [
              {
                "type": "TextBody",
                "text": "${data.no_classes_text}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Complete",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "component_action": "complete_subject_configuration",
                "selected_subject_ids": "${data.selected_subject_ids}",
                "subject1_selected_class_ids": "${form.subject1_selected_class_ids}",
                "subject2_selected_class_ids": "${form.subject2_selected_class_ids}",
                "subject3_selected_class_ids": "${form.subject3_selected_class_ids}"
              }
            }
          }
        ]
      }
    }
  ]
}
